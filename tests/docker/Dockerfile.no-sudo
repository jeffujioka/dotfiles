FROM ubuntu:24.04

# Bootstrap: python3 to parse manifest, curl+git for Homebrew and asdf,
# build-essential because Homebrew on Linux requires a C compiler for
# source builds when bottles are unavailable.
RUN apt-get update && apt-get install -y python3 curl git build-essential \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

ARG TEST_USER=testuser
ARG TEST_UID=1000

RUN useradd -m -d /home/${TEST_USER} -s /bin/bash -u ${TEST_UID} ${TEST_USER} 2>/dev/null || \
    useradd -m -d /home/${TEST_USER} -s /bin/bash ${TEST_USER}

USER ${TEST_USER}
WORKDIR /home/${TEST_USER}
RUN mkdir -p /home/${TEST_USER}/.local/bin
ENV PATH="/home/${TEST_USER}/.local/bin:${PATH}"
